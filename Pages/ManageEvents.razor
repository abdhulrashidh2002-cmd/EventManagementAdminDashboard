@page "/ManageEvents"
@page "/ManageEvents/{Id}"
@using EventManagement.Models
@using EventManagement.Services
@using Microsoft.AspNetCore.Components.Forms
@inject AuthService AuthService
@inject IJSRuntime JS
@inject NavigationManager Nav

<PageTitle>Manage Events</PageTitle>

<h3>Manage Events</h3>
<hr />

<EditForm Model="@Event" OnValidSubmit="HandleSubmit">
    <div class="container">

        <!-- Event Form Fields -->
        <div class="row mb-3">
            <label class="col-sm-2 col-form-label">Title</label>
            <div class="col-sm-10">
                <InputText class="form-control" required @bind-Value="Event.Title" />
            </div>
        </div>

        <div class="row mb-3">
            <label class="col-sm-2 col-form-label">Category</label>
            <div class="col-sm-10">
                <InputText class="form-control" required @bind-Value="Event.Category" />
            </div>
        </div>

        <div class="row mb-3">
            <label class="col-sm-2 col-form-label">Capacity</label>
            <div class="col-sm-10">
                <InputNumber TValue="int" class="form-control" @bind-Value="Event.Capacity" />
            </div>
        </div>

        <div class="row mb-3">
            <label class="col-sm-2 col-form-label">Date</label>
            <div class="col-sm-10">
                <InputDate TValue="DateTime" class="form-control" @bind-Value="Event.Date" />
            </div>
        </div>

        <div class="row mb-3">
            <label class="col-sm-2 col-form-label">Ticket Price</label>
            <div class="col-sm-10">
                <InputNumber TValue="int" class="form-control" @bind-Value="Event.Price" />
            </div>
        </div>

        <div class="row mb-3">
            <label class="col-sm-2 col-form-label">Status</label>
            <div class="col-sm-10">
                <InputText class="form-control" required @bind-Value="Event.Status" />
            </div>
        </div>

        <div class="row mb-3">
            <label class="col-sm-2 col-form-label">Location</label>
            <div class="col-sm-10">
                <InputText class="form-control" required @bind-Value="Event.Location" />
            </div>
        </div>

        <div class="row mb-3">
            <label class="col-sm-2 col-form-label">Description</label>
            <div class="col-sm-10">
                <InputText class="form-control" required @bind-Value="Event.Description" />
            </div>
        </div>

        <div class="row mb-3">
            <label class="col-sm-2 col-form-label">Select Image</label>
            <div class="col-sm-10">
                <InputFile OnChange="OnInputFileChange" />
            </div>
        </div>

        <!-- Status Message -->
        @if (!string.IsNullOrEmpty(statusMessage))
        {
            <div class="alert alert-info">@statusMessage</div>
        }

        <!-- Buttons -->
        <div class="row">
            <div class="col-sm-10 offset-sm-2">
                <button type="submit" class="btn btn-primary" disabled="@isSubmitting">
                    @(isSubmitting ? "Saving data..." : "Save Event")
                </button>
                <button class="btn btn-success" @onclick='() => Nav.NavigateTo("/ViewEvents")'>
                    View Events
                </button>
            </div>
        </div>

    </div>
</EditForm>

@code {

    private EventModel Event = new EventModel();


    private bool isSubmitting = false;
    private string statusMessage = "";
    private IBrowserFile? selectedFile;


    [Parameter] public string? Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        var user = await AuthService.GetCurrentUserAsync();

        if (user == null)
        {
            Nav.NavigateTo("/Login");
            return;
        }

        if (!string.Equals(user.Role, "admin", StringComparison.OrdinalIgnoreCase))
        {
            Nav.NavigateTo("/");
            return;
        }

        await LoadData();
    }
    private async Task LoadData()
    {
        if (!string.IsNullOrEmpty(Id))
        {
            var result = await JS.InvokeAsync<EventModel>("firebaseInterop.getEventById", Id);
            if (result != null)
            {
                Event = result;
            }
        }
    }


    private async Task OnInputFileChange(InputFileChangeEventArgs e)
    {
        selectedFile = e.File;
        var buffer = new byte[e.File.Size];
        await e.File.OpenReadStream(1024 * 500).ReadAsync(buffer);
        Event.ImageUrl = $"data:{e.File.ContentType};base64,{Convert.ToBase64String(buffer)}";
    }

    private async Task HandleSubmit()
    {
        isSubmitting = true;
        statusMessage = "";

        try
        {

            if (selectedFile != null)
            {
                var buffer = new byte[selectedFile.Size];
                using var stream = selectedFile.OpenReadStream(maxAllowedSize: 1024 * 500);
                await stream.ReadAsync(buffer);
                Event.ImageUrl = $"data:{selectedFile.ContentType};base64,{Convert.ToBase64String(buffer)}";
            }


            if (string.IsNullOrEmpty(Id))
            {
                var result = await JS.InvokeAsync<FirebaseResult>("firebaseInterop.SaveEvent", Event);
                if (result.Success && !string.IsNullOrEmpty(result.Id))
                {
                    Event.Id = result.Id;
                    statusMessage = "Event Added Successfully";
                    Nav.NavigateTo("/ManageEvents");
                }
                else
                {
                    statusMessage = $"Error: {result.Error}";
                }
            }

            else
            {
                var result = await JS.InvokeAsync<FirebaseResult>("firebaseInterop.UpdateEvent", Id, Event);
                if (result.Success)
                {
                    statusMessage = "Event Updated Successfully";
                    Nav.NavigateTo("/ViewEvents");
                }
                else
                {
                    statusMessage = $"Error: {result.Error}";
                }
            }
        }


        catch (Exception ex)
        {
            statusMessage = $"Error: Saving Event data - {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }


    public class FirebaseResult
    {
        public bool Success { get; set; }
        public string? Id { get; set; }
        public string? Error { get; set; }
    }
}