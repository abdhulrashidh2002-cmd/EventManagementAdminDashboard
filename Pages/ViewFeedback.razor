@page "/ViewFeedbacks"
@using EventManagement.Models
@inject IJSRuntime JS
@inject NavigationManager Nav
@using EventManagement.Services
@inject AuthService AuthService


<h3>Event Feedbacks</h3>
<hr />

<div class="mb-4">
    <label class="form-label">Select Event:</label>
    <select class="form-select" @bind="SelectedEventId">
        <option value="">-- Select Event --</option>
        @foreach (var ev in Events)
        {
            <option value="@ev.Id">@ev.Title</option>
        }
    </select>
</div>

@if (IsLoading)
{
    <div class="d-flex justify-content-center my-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (string.IsNullOrEmpty(SelectedEventId))
{
    <div class="alert alert-warning">Please select an event to view feedbacks.</div>
}
else if (!Feedbacks.Any())
{
    <div class="alert alert-info">No feedbacks found for this event.</div>
}
else
{
    <p>Total feedbacks: @Feedbacks.Count</p>
    <div class="row">
        @foreach (var fb in Feedbacks)
        {
            <div class="col-md-4 col-sm-6 mb-4">
                <div class="card shadow-sm h-100 hover-shadow">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title mb-2">@fb.FullName</h5>
                        <h6 class="card-subtitle mb-2 text-muted">@fb.Email</h6>
                        <div class="mb-2">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <span class="text-warning">
                                    @(i <= fb.Rating ? "★" : "☆")
                                </span>
                            }
                        </div>
                        <p class="card-text flex-grow-1">@fb.Comment</p>
                        <small class="text-muted mt-auto">
                            @fb.Date?.ToString("dd MMM yyyy HH:mm")
                        </small>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private List<EventModel> Events = new();
    private List<FeedbackModel> Feedbacks = new();

    private string _selectedEventId = "";
    private string SelectedEventId
    {
        get => _selectedEventId;
        set
        {
            if (_selectedEventId != value)
            {
                _selectedEventId = value;
                _ = InvokeAsync(LoadFeedbacksAsync);
            }
        }
    }

    private bool IsLoading = true;

    protected override async Task OnInitializedAsync()
    {

        var user = await AuthService.GetCurrentUserAsync();


        if (user == null)
        {
            Nav.NavigateTo("/Login");
            return;
        }


        if (user.Role != "admin")
        {
            Nav.NavigateTo("/");
            return;
        }


        // Load events for dropdown
        await LoadEventsAsync();
    }
        

        
    

    private async Task LoadEventsAsync()
    {
        try
        {
            IsLoading = true;
            Events = await JS.InvokeAsync<List<EventModel>>("firebaseInterop.getEvents") ?? new List<EventModel>();
        }
        catch (Exception ex)
        {
            Console.WriteLine("Error loading events: " + ex.Message);
            Events = new List<EventModel>();
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }

    private async Task LoadFeedbacksAsync()
    {
        if (string.IsNullOrEmpty(SelectedEventId))
        {
            Feedbacks.Clear();
            StateHasChanged();
            return;
        }

        IsLoading = true;
        try
        {
            Feedbacks = await JS.InvokeAsync<List<FeedbackModel>>(
                "firebaseInterop.getFeedbacks", SelectedEventId) ?? new List<FeedbackModel>();
        }
        catch (Exception ex)
        {
            Console.WriteLine("Error loading feedbacks: " + ex.Message);
            Feedbacks = new List<FeedbackModel>();
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }

    public class FeedbackModel
    {
        public string Id { get; set; } = "";
        public string Email { get; set; } = "";
        public string FullName { get; set; } = "";
        public string Comment { get; set; } = "";
        public int Rating { get; set; } = 0;
        public DateTime? Date { get; set; }
    }
}