@page "/"
@using EventManagement.Models
@inject IJSRuntime JS
@inject NavigationManager Nav
@using EventManagement.Services
@inject AuthService AuthService

<PageTitle>Admin Dashboard</PageTitle>

<h3>Admin Dashboard</h3>
<hr />
<button class="btn btn-danger" @onclick='() => Nav.NavigateTo("/CreateAdmin")'>Add new Admin</button>
<button class="btn btn-dark " @onclick="logout">Logout</button>

<hr />
@if (IsLoading)
{
    <div class="d-flex justify-content-center my-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else
{
    
    <div class="row mb-4">
        <div class="col-md-3 mb-3">
            <div class="card text-white bg-primary h-100">
                <div class="card-body">
                    <h5 class="card-title">Total Events</h5>
                    <p class="card-text fs-3">@Events.Count</p>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card text-white bg-success h-100">
                <div class="card-body">
                    <h5 class="card-title">Total Feedbacks</h5>
                    <p class="card-text fs-3">@Feedbacks.Count</p>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card text-white bg-warning h-100">
                <div class="card-body">
                    <h5 class="card-title">Total RSVPs</h5>
                    <p class="card-text fs-3">@TotalRsvps</p>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card text-white bg-info h-100">
                <div class="card-body">
                    <h5 class="card-title">Upcoming Events</h5>
                    <p class="card-text fs-3">@UpcomingEvents.Count</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Upcoming Events Table -->
    <h5>Upcoming Events</h5>
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Title</th>
                <th>Date</th>
                <th>Capacity</th>
                <th>Status</th>
                
            </tr>
        </thead>
        <tbody>
            @foreach (var ev in UpcomingEvents)
            {
                <tr>
                    <td>@ev.Title</td>
                    <td>@ev.Date.ToString("dd MMM yyyy")</td>
                    <td>@ev.Capacity</td>
                    <td>@ev.Status</td>
                    
                </tr>
            }
        </tbody>
    </table>

    <!-- Recent Feedbacks -->
    <h5 class="mt-5">Recent Feedbacks</h5>
    @if (!Feedbacks.Any())
    {
        <div class="alert alert-info">No feedbacks yet.</div>
    }
    else
    {
        @* @foreach (var fb in Feedbacks) *@
        <div class="row">
            @foreach (var fb in Feedbacks.OrderByDescending(f => f.Date).Take(5))
            {
                <div class="col-md-4 col-sm-6 mb-4">
                    <div class="card shadow-sm h-100 hover-shadow">
                        <div class="card-body d-flex flex-column">
                            
                            <h5 class="card-title mb-2">@fb.FullName</h5>
                            <h6 class="card-subtitle mb-2 text-muted">@fb.Email</h6>
                            <div class="mb-2">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <span class="text-warning">
                                        @(i <= fb.Rating ? "★" : "☆")
                                    </span>
                                }
                            </div>
                            <p class="card-text flex-grow-1">@fb.Comment</p>
                            <small class="text-muted mt-auto">
                                @fb.Date?.ToString("dd MMM yyyy HH:mm")
                            </small>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
}

@code {
    private bool IsLoading = true;
    private List<EventModel> Events = new();
    private List<EventModel> UpcomingEvents => Events.Where(e => e.Date >= DateTime.Now).OrderBy(e => e.Date).Take(5).ToList();
    private List<FeedbackModel> Feedbacks = new();
    private List<Rsvp> rsvps = new();
    private int TotalRsvps = 0;

    protected override async Task OnInitializedAsync()
    {
        var user = await AuthService.GetCurrentUserAsync();
        if (user == null)
        {
            Nav.NavigateTo("/Login");
            return;
        }

        if (!string.Equals(user.Role, "admin", StringComparison.OrdinalIgnoreCase))
        {
            Nav.NavigateTo("/");
            return;
        }

        await LoadData();
    }

    private async Task LoadData()
    {
        IsLoading = true;
        try
        {
            Events = await JS.InvokeAsync<List<EventModel>>("firebaseInterop.getEvents") ?? new List<EventModel>();
            Feedbacks = new List<FeedbackModel>();
            foreach (var ev in Events)
            {
                var fb = await JS.InvokeAsync<List<FeedbackModel>>("firebaseInterop.getFeedbacks", ev.Id) ?? new List<FeedbackModel>();
                Feedbacks.AddRange(fb);
            }


            foreach (var ev in Events)
            {
                var rsvps = await JS.InvokeAsync<List<Rsvp>>("firebaseInterop.getRsvps", ev.Id) ?? new List<Rsvp>();
                TotalRsvps += rsvps.Count;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine("Error loading admin dashboard: " + ex.Message);
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }

    private void EditEvent(string id) => Nav.NavigateTo($"/ManageEvents/{id}");
    public class EventViewModel : EventModel { }
    private async Task DeleteEvent(string id)
    {
        var confirm = await JS.InvokeAsync<bool>("confirm", "Are you sure you want to delete this event?");
        if (confirm)
        {
            await JS.InvokeVoidAsync("firebaseInterop.deleteEvent", id);
            Events.RemoveAll(e => e.Id == id);
            StateHasChanged();
        }
    }

    private async Task logout()
    {
        if (await JS.InvokeAsync<bool>("confirm",
                    "Do you want to logout?"))
        {
            await JS.InvokeVoidAsync("firebaseAuth.logout");
            Nav.NavigateTo("/Login?message=Logout successful");
        }
       
    }
 
    public class FeedbackModel
    {
        public string Id { get; set; } = "";
        public string Email { get; set; } = "";
        public string FullName { get; set; } = "";
        public string Comment { get; set; } = "";
        public int Rating { get; set; } = 0;
        public DateTime? Date { get; set; }
    }
}